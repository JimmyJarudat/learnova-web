generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SocialProvider {
  FACEBOOK
  GOOGLE
  LINE
  GITHUB
}

enum ExamPartKind {
  PART_A_GENERAL
  PART_B_PROFESSION
  PART_B_MAJOR
  PART_C_INTERVIEW
  PRACTICE
}

enum ExamQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum ExamContentFormat {
  PLAIN_TEXT
  MARKDOWN
  HTML
}

enum ExamAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
  CANCELLED
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String    @unique
  passwordHash    String?
  displayName     String?
  avatarUrl       String?
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  socialAccounts       SocialAccount[]
  passwordResetTokens PasswordResetToken[]
  examAttempts        ExamAttempt[]

  @@index([email])
  @@index([username])
  @@map("users")
}

/// เก็บสังกัด/สนามสอบ เช่น สพฐ. สอศ. สกร. อปท. กทม.
/// ใช้เป็นด่านแรกของ flow: ผู้ใช้เลือกสังกัดก่อน แล้วค่อยเลือกเอกและชุดข้อสอบ
model ExamAffiliation {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(80)
  label       String   @db.VarChar(50)
  name        String   @db.VarChar(180)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.Text
  colorClass  String?  @map("color_class") @db.VarChar(80)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tracks       ExamTrack[]
  practiceSets PracticeSetAffiliation[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("exam_affiliations")
}

/// เก็บเอก/สาขาที่ผู้ใช้สมัครสอบ เช่น เอกคอมพิวเตอร์ เอกคณิตศาสตร์ เอกภาษาอังกฤษ
/// แยกออกจากภาคสอบ เพราะเอกไม่ใช่ภาค ก/ข/ค แต่เป็นเป้าหมายของผู้สอบ
model ExamMajor {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(150)
  shortName   String?  @map("short_name") @db.VarChar(80)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tracks ExamTrack[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("exam_majors")
}

/// ผูกสังกัดกับเอก เป็นเส้นทางสอบของผู้ใช้ เช่น สพฐ. + เอกคอมพิวเตอร์
/// หน้า /exams/obec ให้เลือก record กลุ่มนี้ก่อน เพื่อไม่ให้ผู้ใช้ต้องไล่หา ภาค ข ของเอกเอง
model ExamTrack {
  id            String   @id @default(uuid()) @db.Uuid
  affiliationId String   @map("affiliation_id") @db.Uuid
  majorId       String   @map("major_id") @db.Uuid
  slug          String   @db.VarChar(140)
  title         String   @db.VarChar(220)
  description   String?  @db.Text
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  affiliation ExamAffiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)
  major       ExamMajor       @relation(fields: [majorId], references: [id], onDelete: Cascade)
  packages    ExamPackage[]

  @@unique([affiliationId, majorId])
  @@unique([affiliationId, slug])
  @@index([majorId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("exam_tracks")
}

/// เก็บปี/ชุดข้อสอบของเส้นทางนั้น เช่น สพฐ. เอกคอม ปี 2567 ชุดที่ 1
/// ผู้ใช้เลือกชุดนี้ก่อน แล้วหน้าถัดไปจะให้เลือกว่าจะทำ ภาค ก ภาค ข วิชาชีพ ภาค ข วิชาเอก หรือ ภาค ค
model ExamPackage {
  id          String   @id @default(uuid()) @db.Uuid
  trackId     String   @map("track_id") @db.Uuid
  slug        String   @db.VarChar(140)
  title       String   @db.VarChar(255)
  year        String   @db.VarChar(30)
  label       String?  @db.VarChar(80)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  track ExamTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  parts ExamPackagePart[]

  @@unique([trackId, slug])
  @@index([year])
  @@index([isActive])
  @@index([sortOrder])
  @@map("exam_packages")
}

/// เก็บภาคที่อยู่ในชุดข้อสอบหนึ่งชุด เช่น ภาค ก, ภาค ข วิชาชีพครู, ภาค ข เอกคอม, ภาค ค
/// หน้านี้คือจุดที่ผู้ใช้เลือกว่าจะลองทำอันไหน หลังจากเลือกสังกัด เอก และปี/ชุดแล้ว
model ExamPackagePart {
  id              String       @id @default(uuid()) @db.Uuid
  packageId       String       @map("package_id") @db.Uuid
  slug            String       @db.VarChar(140)
  kind            ExamPartKind
  title           String       @db.VarChar(255)
  shortTitle      String?      @map("short_title") @db.VarChar(80)
  audienceLabel   String?      @map("audience_label") @db.VarChar(120)
  description     String?      @db.Text
  durationMinutes Int          @default(60) @map("duration_minutes")
  totalQuestions  Int          @default(0) @map("total_questions")
  totalScore      Decimal      @default(0) @map("total_score") @db.Decimal(8, 2)
  difficulty      String?      @db.VarChar(50)
  sortOrder       Int          @default(0) @map("sort_order")
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  package  ExamPackage               @relation(fields: [packageId], references: [id], onDelete: Cascade)
  items    ExamPackagePartQuestion[]
  attempts ExamAttempt[]
  sections ExamSection[]

  @@unique([packageId, slug])
  @@index([kind])
  @@index([isActive])
  @@index([sortOrder])
  @@map("exam_package_parts")
}

/// เก็บหัวข้อคั่นระหว่างข้อ เช่น ตอนที่ 1 ความสามารถด้านเหตุผล, ตอนที่ 2 ภาษาไทย
/// ใช้แสดงเป็นแถบหัวข้อในหน้าทำข้อสอบ โดยไม่ต้องสร้างเป็นคำถามปลอม
model ExamSection {
  id            String   @id @default(uuid()) @db.Uuid
  partId        String?  @map("part_id") @db.Uuid
  practiceSetId String?  @map("practice_set_id") @db.Uuid
  title         String   @db.VarChar(255)
  description   String?  @db.Text
  contentFormat ExamContentFormat @default(MARKDOWN) @map("content_format")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  part          ExamPackagePart? @relation(fields: [partId], references: [id], onDelete: Cascade)
  practiceSet   PracticeSet?     @relation(fields: [practiceSetId], references: [id], onDelete: Cascade)
  packageItems  ExamPackagePartQuestion[]
  practiceItems PracticeSetQuestion[]

  @@index([partId])
  @@index([practiceSetId])
  @@index([sortOrder])
  @@map("exam_sections")
}

/// เก็บหมวดฝึกแบบไม่ต้องเลือกสังกัด/เอกก่อน เช่น ภาค ก รวมทุกสังกัด กฎหมาย วิชาชีพครู
/// ใช้แก้ปัญหาผู้ใช้ที่อยากฝึก ภาค ก หลายชุดติดกันโดยไม่เข้า flow สังกัด-เอก
model PracticeCategory {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(100)
  title       String   @db.VarChar(180)
  shortTitle  String?  @map("short_title") @db.VarChar(80)
  description String?  @db.Text
  colorClass  String?  @map("color_class") @db.VarChar(80)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  sets PracticeSet[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("practice_categories")
}

/// เก็บชุดฝึกตามหมวด เช่น ภาค ก ชุดพื้นฐาน 1, ภาค ก จับเวลา 30 ข้อ
/// ชุดนี้อยู่นอกเส้นทางสังกัด-เอก และเหมาะกับการฝึกหัวข้อซ้ำหลายชุด
model PracticeSet {
  id              String   @id @default(uuid()) @db.Uuid
  categoryId      String   @map("category_id") @db.Uuid
  slug            String   @db.VarChar(140)
  title           String   @db.VarChar(255)
  scopeLabel      String?  @map("scope_label") @db.VarChar(120)
  yearLabel       String?  @map("year_label") @db.VarChar(50)
  description     String?  @db.Text
  durationMinutes Int      @default(30) @map("duration_minutes")
  totalQuestions  Int      @default(0) @map("total_questions")
  totalScore      Decimal  @default(0) @map("total_score") @db.Decimal(8, 2)
  difficulty      String?  @db.VarChar(50)
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  category     PracticeCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  affiliations PracticeSetAffiliation[]
  items        PracticeSetQuestion[]
  attempts     ExamAttempt[]
  sections     ExamSection[]

  @@unique([categoryId, slug])
  @@index([isActive])
  @@index([sortOrder])
  @@map("practice_sets")
}

/// ผูกชุดฝึกตามหมวดกับหลายสังกัด เช่น ภาค ก ชุดเดียวใช้ได้ทั้ง สพฐ. สอศ. สกร.
/// ใช้ filter ชุดฝึกตามสังกัดได้จริง แทนการพึ่งข้อความ scope_label อย่างเดียว
model PracticeSetAffiliation {
  id            String   @id @default(uuid()) @db.Uuid
  practiceSetId String   @map("practice_set_id") @db.Uuid
  affiliationId String   @map("affiliation_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  practiceSet PracticeSet     @relation(fields: [practiceSetId], references: [id], onDelete: Cascade)
  affiliation ExamAffiliation @relation(fields: [affiliationId], references: [id], onDelete: Cascade)

  @@unique([practiceSetId, affiliationId])
  @@index([affiliationId])
  @@map("practice_set_affiliations")
}

/// คลังคำถามกลาง ใช้ซ้ำได้ทั้งชุดตามสนามและชุดฝึกตามหมวด
/// คำถามหนึ่งข้ออาจถูกนำไปอยู่หลายชุด ผ่านตาราง join ของ package part หรือ practice set
model ExamQuestion {
  id              String           @id @default(uuid()) @db.Uuid
  passageId       String?          @map("passage_id") @db.Uuid
  type            ExamQuestionType @default(SINGLE_CHOICE)
  contentFormat   ExamContentFormat @default(MARKDOWN) @map("content_format")
  stem            String           @db.Text
  inlinePassage   String?          @map("passage") @db.Text
  imageUrl        String?          @map("image_url") @db.Text
  explanation     String?          @db.Text
  explanationFormat ExamContentFormat @default(MARKDOWN) @map("explanation_format")
  explanationImageUrl String?      @map("explanation_image_url") @db.Text
  difficulty      String?          @db.VarChar(50)
  tags            String[]         @default([])
  sourceLabel     String?          @map("source_label") @db.VarChar(150)
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  sharedPassage ExamPassage? @relation(fields: [passageId], references: [id], onDelete: SetNull)
  choices       ExamQuestionChoice[]
  assets        ExamQuestionAsset[]
  acceptedAnswers ExamQuestionAcceptedAnswer[]
  packageItems  ExamPackagePartQuestion[]
  practiceItems PracticeSetQuestion[]
  answers       ExamAttemptAnswer[]

  @@index([passageId])
  @@index([type])
  @@index([difficulty])
  @@index([isActive])
  @@map("exam_questions")
}

/// เก็บข้อความ/สถานการณ์/บทอ่านร่วมที่ใช้ตอบหลายข้อ เช่น "จากข้อความนี้ใช้ตอบคำถามข้อ 1-5"
/// คำถามหลายข้อสามารถชี้ passage เดียวกันผ่าน ExamQuestion.passageId ได้
model ExamPassage {
  id            String   @id @default(uuid()) @db.Uuid
  title         String?  @db.VarChar(255)
  content       String   @db.Text
  contentFormat ExamContentFormat @default(MARKDOWN) @map("content_format")
  imageUrl      String?  @map("image_url") @db.Text
  sourceLabel   String?  @map("source_label") @db.VarChar(150)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  questions ExamQuestion[]

  @@index([sortOrder])
  @@map("exam_passages")
}

/// เก็บรูป/ไฟล์ประกอบของคำถามได้หลายรายการ เช่น ตาราง กราฟ รูปเรขาคณิต หรือภาพประกอบเฉลย
/// ถ้ามีรูปเดียวใช้ ExamQuestion.imageUrl ได้ แต่ถ้ามีหลายรูปให้ใช้ตารางนี้
model ExamQuestionAsset {
  id          String   @id @default(uuid()) @db.Uuid
  questionId  String   @map("question_id") @db.Uuid
  url         String   @db.Text
  altText     String?  @map("alt_text") @db.VarChar(255)
  caption     String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([sortOrder])
  @@map("exam_question_assets")
}

/// เก็บตัวเลือกของคำถาม เช่น ก ข ค ง พร้อมบอกว่าข้อไหนถูก
/// รองรับ single choice และ multiple choice โดยให้มี isCorrect ได้มากกว่าหนึ่งตัวเลือก
model ExamQuestionChoice {
  id          String   @id @default(uuid()) @db.Uuid
  questionId  String   @map("question_id") @db.Uuid
  label       String   @db.VarChar(20)
  text        String   @db.Text
  contentFormat ExamContentFormat @default(MARKDOWN) @map("content_format")
  imageUrl    String?  @map("image_url") @db.Text
  isCorrect   Boolean  @default(false) @map("is_correct")
  explanation String?  @db.Text
  explanationFormat ExamContentFormat @default(MARKDOWN) @map("explanation_format")
  explanationImageUrl String? @map("explanation_image_url") @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerChoices  ExamAttemptAnswerChoice[]

  @@unique([questionId, label])
  @@index([questionId])
  @@index([sortOrder])
  @@map("exam_question_choices")
}

/// เก็บคำตอบที่ยอมรับได้สำหรับ SHORT_ANSWER
/// ใช้กรณีข้อสอบแบบพิมพ์คำตอบสั้น เช่น ชื่อกฎหมาย คำสำคัญ หรือผลลัพธ์ตัวเลข
model ExamQuestionAcceptedAnswer {
  id             String   @id @default(uuid()) @db.Uuid
  questionId     String   @map("question_id") @db.Uuid
  text           String   @db.Text
  normalizedText String?  @map("normalized_text") @db.Text
  contentFormat  ExamContentFormat @default(PLAIN_TEXT) @map("content_format")
  isCaseSensitive Boolean @default(false) @map("is_case_sensitive")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("exam_question_accepted_answers")
}

/// ตาราง join ระหว่างภาคในชุดข้อสอบกับคำถาม
/// ใช้กำหนดลำดับข้อ คะแนนต่อข้อ และ override คำอธิบายเฉพาะชุดได้ในอนาคต
model ExamPackagePartQuestion {
  id        String   @id @default(uuid()) @db.Uuid
  partId    String   @map("part_id") @db.Uuid
  sectionId String?  @map("section_id") @db.Uuid
  questionId String  @map("question_id") @db.Uuid
  position  Int
  score     Decimal  @default(1) @db.Decimal(8, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  part     ExamPackagePart @relation(fields: [partId], references: [id], onDelete: Cascade)
  section  ExamSection?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  question ExamQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([partId, questionId])
  @@unique([partId, position])
  @@index([sectionId])
  @@index([questionId])
  @@map("exam_package_part_questions")
}

/// ตาราง join ระหว่างชุดฝึกตามหมวดกับคำถาม
/// ทำให้ชุด ภาค ก หลายชุดดึงคำถามจากคลังกลางมาเรียงและให้คะแนนต่างกันได้
model PracticeSetQuestion {
  id        String   @id @default(uuid()) @db.Uuid
  setId     String   @map("set_id") @db.Uuid
  sectionId String?  @map("section_id") @db.Uuid
  questionId String  @map("question_id") @db.Uuid
  position  Int
  score     Decimal  @default(1) @db.Decimal(8, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  set      PracticeSet  @relation(fields: [setId], references: [id], onDelete: Cascade)
  section  ExamSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([setId, questionId])
  @@unique([setId, position])
  @@index([sectionId])
  @@index([questionId])
  @@map("practice_set_questions")
}

/// เก็บการเริ่มทำข้อสอบของผู้ใช้หนึ่งครั้ง
/// attempt จะชี้ได้อย่างใดอย่างหนึ่ง: part ของชุดตามสนาม หรือ practice set ของหมวดฝึก
model ExamAttempt {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @map("user_id")
  packagePartId String?           @map("package_part_id") @db.Uuid
  practiceSetId String?           @map("practice_set_id") @db.Uuid
  status        ExamAttemptStatus @default(IN_PROGRESS)
  startedAt     DateTime          @default(now()) @map("started_at") @db.Timestamptz(6)
  submittedAt   DateTime?         @map("submitted_at") @db.Timestamptz(6)
  expiresAt     DateTime?         @map("expires_at") @db.Timestamptz(6)
  totalQuestions Int              @default(0) @map("total_questions")
  answeredCount  Int              @default(0) @map("answered_count")
  score          Decimal          @default(0) @db.Decimal(8, 2)
  maxScore       Decimal          @default(0) @map("max_score") @db.Decimal(8, 2)
  durationSeconds Int?            @map("duration_seconds")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  packagePart ExamPackagePart? @relation(fields: [packagePartId], references: [id], onDelete: SetNull)
  practiceSet PracticeSet?     @relation(fields: [practiceSetId], references: [id], onDelete: SetNull)
  answers     ExamAttemptAnswer[]

  @@index([userId])
  @@index([packagePartId])
  @@index([practiceSetId])
  @@index([status])
  @@index([startedAt])
  @@map("exam_attempts")
}

/// เก็บคำตอบรายข้อของผู้ใช้ใน attempt หนึ่งครั้ง
/// รองรับทั้งเลือกตัวเลือกและคำตอบแบบข้อความสั้นในอนาคต
model ExamAttemptAnswer {
  id                String   @id @default(uuid()) @db.Uuid
  attemptId         String   @map("attempt_id") @db.Uuid
  questionId        String   @map("question_id") @db.Uuid
  textAnswer        String?  @map("text_answer") @db.Text
  isCorrect         Boolean? @map("is_correct")
  score             Decimal  @default(0) @db.Decimal(8, 2)
  answeredAt        DateTime @default(now()) @map("answered_at") @db.Timestamptz(6)

  attempt        ExamAttempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       ExamQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedChoices ExamAttemptAnswerChoice[]

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@map("exam_attempt_answers")
}

/// เก็บตัวเลือกที่ผู้ใช้เลือกแบบหลายข้อ
/// ใช้กับ MULTIPLE_CHOICE โดยหนึ่งคำตอบสามารถมี selected choices ได้หลายรายการ
model ExamAttemptAnswerChoice {
  id        String   @id @default(uuid()) @db.Uuid
  answerId  String   @map("answer_id") @db.Uuid
  choiceId  String   @map("choice_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  answer ExamAttemptAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  choice ExamQuestionChoice @relation(fields: [choiceId], references: [id], onDelete: Cascade)

  @@unique([answerId, choiceId])
  @@index([choiceId])
  @@map("exam_attempt_answer_choices")
}

model SocialAccount {
  id                String         @id @default(uuid())
  userId            String
  provider          SocialProvider
  providerAccountId String
  providerEmail     String?
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?
  idToken           String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("social_accounts")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model system_config {
  id                  String    @id @db.VarChar(50)
  value               String    @db.VarChar(4000)
  description         String?   @db.VarChar(4000)
  created_at          DateTime  @default(now()) @db.Timestamp(6)
  updated_at          DateTime  @default(now()) @db.Timestamp(6)
  category            String    @default("GENERAL") @db.VarChar(50)
  is_active           Boolean   @default(true)
  is_encrypted        Boolean   @default(false)
  last_modified_by_id String?
  display_name        String?   @db.VarChar(100)
  data_type           String    @default("STRING") @db.VarChar(20)

  @@index([category, is_active], map: "ix_system_config_category_is_active")
  @@map("system_config")
}


model NewsSource {
  id          String    @id @default(uuid()) @db.Uuid

  name        String    @db.VarChar(150)
  url         String    @unique @db.Text

  /// government, teacher_exam, education_news, social, other
  type        String    @default("other") @db.VarChar(50)

  isActive    Boolean   @default(true) @map("is_active")
  lastFetchAt DateTime? @map("last_fetch_at") @db.Timestamptz(6)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  articles    NewsArticle[]

  @@index([type])
  @@index([isActive])
  @@map("news_sources")
}

model NewsCategory {
  id          String   @id @default(uuid()) @db.Uuid

  nameTh      String   @map("name_th") @db.VarChar(100)
  nameEn      String?  @map("name_en") @db.VarChar(100)

  /// teacher-exam, obec, otep, ksp, recruitment
  slug        String   @unique @db.VarChar(120)

  description String?  @db.Text

  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  articles    NewsArticle[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("news_categories")
}

model NewsArticle {
  id                String        @id @default(uuid()) @db.Uuid

  sourceId          String?       @map("source_id") @db.Uuid
  source            NewsSource?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  categoryId        String?       @map("category_id") @db.Uuid
  category          NewsCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  title             String        @db.VarChar(255)
  slug              String        @unique @db.VarChar(255)

  excerpt           String?       @db.VarChar(500)
  summary           String?       @db.Text
  content           String?       @db.Text

  sourceName        String?       @map("source_name") @db.VarChar(150)
  sourceUrl         String        @unique @map("source_url") @db.Text
  imageUrl          String?       @map("image_url") @db.Text

  tags              String[]      @default([])

  /// draft, published, upcoming, open, closing_soon, closed, cancelled, archived
  status            String        @default("published") @db.VarChar(30)

  /// วันที่เริ่มรับสมัคร ใช้กับข่าวสมัครงาน/เปิดสอบ
  applicationStart  DateTime?     @map("application_start") @db.Date

  /// วันที่สิ้นสุดรับสมัคร ใช้คำนวณ open / closing_soon / closed
  applicationEnd    DateTime?     @map("application_end") @db.Date

  /// เวลาที่ระบบ mark ว่าปิดรับสมัครแล้ว
  closedAt          DateTime?     @map("closed_at") @db.Timestamptz(6)

  /// เวลาที่ mark ว่าประกาศถูกยกเลิก
  cancelledAt       DateTime?     @map("cancelled_at") @db.Timestamptz(6)

  /// เวลาที่เก็บถาวร
  archivedAt        DateTime?     @map("archived_at") @db.Timestamptz(6)

  /// id จากต้นทาง เช่น JOB OCSC: 10859
  /// ใช้สำหรับ sync/upsert คู่กับ sourceId
  externalId        String?       @map("external_id") @db.VarChar(100)

  /// เวลาล่าสุดที่ workflow ยังเจอข่าวนี้จากต้นทาง
  lastSeenAt        DateTime?     @map("last_seen_at") @db.Timestamptz(6)

  relevanceScore    Int           @default(0) @map("relevance_score")
  viewCount         Int           @default(0) @map("view_count")

  isFeatured        Boolean       @default(false) @map("is_featured")

  sourcePublishedAt DateTime?     @map("source_published_at") @db.Timestamptz(6)
  publishedAt       DateTime?     @map("published_at") @db.Timestamptz(6)
  fetchedAt         DateTime      @default(now()) @map("fetched_at") @db.Timestamptz(6)

  rawData           Json?         @map("raw_data")

  createdBy         String?       @map("created_by") @db.Uuid
  updatedBy         String?       @map("updated_by") @db.Uuid

  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status])
  @@index([categoryId])
  @@index([sourceId])
  @@index([publishedAt])
  @@index([sourcePublishedAt])
  @@index([applicationStart])
  @@index([applicationEnd])
  @@index([lastSeenAt])
  @@index([sourceId, externalId])
  @@index([relevanceScore])
  @@index([viewCount])
  @@index([isFeatured])
  @@map("news_articles")
}

model NewsFetchLog {
  id            String    @id @default(uuid()) @db.Uuid

  sourceId      String?   @map("source_id") @db.Uuid
  sourceName    String?   @map("source_name") @db.VarChar(150)
  sourceUrl     String?   @map("source_url") @db.Text

  /// success, partial_success, failed
  status        String    @default("success") @db.VarChar(30)

  totalFound    Int       @default(0) @map("total_found")
  totalInserted Int       @default(0) @map("total_inserted")
  totalSkipped  Int       @default(0) @map("total_skipped")
  totalFailed   Int       @default(0) @map("total_failed")

  message       String?   @db.Text
  errorMessage  String?   @map("error_message") @db.Text

  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt    DateTime? @map("finished_at") @db.Timestamptz(6)

  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([sourceId])
  @@index([status])
  @@index([startedAt])
  @@map("news_fetch_logs")
}
