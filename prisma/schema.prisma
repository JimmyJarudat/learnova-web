generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SocialProvider {
  FACEBOOK
  GOOGLE
  LINE
  GITHUB
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String    @unique
  passwordHash    String?
  displayName     String?
  avatarUrl       String?
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  socialAccounts       SocialAccount[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([username])
  @@map("users")
}

model SocialAccount {
  id                String         @id @default(uuid())
  userId            String
  provider          SocialProvider
  providerAccountId String
  providerEmail     String?
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?
  idToken           String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("social_accounts")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model system_config {
  id                  String    @id @db.VarChar(50)
  value               String    @db.VarChar(4000)
  description         String?   @db.VarChar(4000)
  created_at          DateTime  @default(now()) @db.Timestamp(6)
  updated_at          DateTime  @default(now()) @db.Timestamp(6)
  category            String    @default("GENERAL") @db.VarChar(50)
  is_active           Boolean   @default(true)
  is_encrypted        Boolean   @default(false)
  last_modified_by_id String?
  display_name        String?   @db.VarChar(100)
  data_type           String    @default("STRING") @db.VarChar(20)

  @@index([category, is_active], map: "ix_system_config_category_is_active")
  @@map("system_config")
}


model NewsSource {
  id          String    @id @default(uuid()) @db.Uuid

  name        String    @db.VarChar(150)
  url         String    @unique @db.Text

  /// government, teacher_exam, education_news, social, other
  type        String    @default("other") @db.VarChar(50)

  isActive    Boolean   @default(true) @map("is_active")
  lastFetchAt DateTime? @map("last_fetch_at") @db.Timestamptz(6)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  articles    NewsArticle[]

  @@index([type])
  @@index([isActive])
  @@map("news_sources")
}

model NewsCategory {
  id          String   @id @default(uuid()) @db.Uuid

  nameTh      String   @map("name_th") @db.VarChar(100)
  nameEn      String?  @map("name_en") @db.VarChar(100)

  /// teacher-exam, obec, otep, ksp, recruitment
  slug        String   @unique @db.VarChar(120)

  description String?  @db.Text

  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  articles    NewsArticle[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("news_categories")
}

model NewsArticle {
  id                String        @id @default(uuid()) @db.Uuid

  sourceId          String?       @map("source_id") @db.Uuid
  source            NewsSource?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  categoryId        String?       @map("category_id") @db.Uuid
  category          NewsCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  title             String        @db.VarChar(255)
  slug              String        @unique @db.VarChar(255)

  excerpt           String?       @db.VarChar(500)
  summary           String?       @db.Text
  content           String?       @db.Text

  sourceName        String?       @map("source_name") @db.VarChar(150)
  sourceUrl         String        @unique @map("source_url") @db.Text
  imageUrl          String?       @map("image_url") @db.Text

  tags              String[]      @default([])

  /// draft, published, upcoming, open, closing_soon, closed, cancelled, archived
  status            String        @default("published") @db.VarChar(30)

  /// วันที่เริ่มรับสมัคร ใช้กับข่าวสมัครงาน/เปิดสอบ
  applicationStart  DateTime?     @map("application_start") @db.Date

  /// วันที่สิ้นสุดรับสมัคร ใช้คำนวณ open / closing_soon / closed
  applicationEnd    DateTime?     @map("application_end") @db.Date

  /// เวลาที่ระบบ mark ว่าปิดรับสมัครแล้ว
  closedAt          DateTime?     @map("closed_at") @db.Timestamptz(6)

  /// เวลาที่ mark ว่าประกาศถูกยกเลิก
  cancelledAt       DateTime?     @map("cancelled_at") @db.Timestamptz(6)

  /// เวลาที่เก็บถาวร
  archivedAt        DateTime?     @map("archived_at") @db.Timestamptz(6)

  /// id จากต้นทาง เช่น JOB OCSC: 10859
  /// ใช้สำหรับ sync/upsert คู่กับ sourceId
  externalId        String?       @map("external_id") @db.VarChar(100)

  /// เวลาล่าสุดที่ workflow ยังเจอข่าวนี้จากต้นทาง
  lastSeenAt        DateTime?     @map("last_seen_at") @db.Timestamptz(6)

  relevanceScore    Int           @default(0) @map("relevance_score")
  viewCount         Int           @default(0) @map("view_count")

  isFeatured        Boolean       @default(false) @map("is_featured")

  sourcePublishedAt DateTime?     @map("source_published_at") @db.Timestamptz(6)
  publishedAt       DateTime?     @map("published_at") @db.Timestamptz(6)
  fetchedAt         DateTime      @default(now()) @map("fetched_at") @db.Timestamptz(6)

  rawData           Json?         @map("raw_data")

  createdBy         String?       @map("created_by") @db.Uuid
  updatedBy         String?       @map("updated_by") @db.Uuid

  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status])
  @@index([categoryId])
  @@index([sourceId])
  @@index([publishedAt])
  @@index([sourcePublishedAt])
  @@index([applicationStart])
  @@index([applicationEnd])
  @@index([lastSeenAt])
  @@index([sourceId, externalId])
  @@index([relevanceScore])
  @@index([viewCount])
  @@index([isFeatured])
  @@map("news_articles")
}

model NewsFetchLog {
  id            String    @id @default(uuid()) @db.Uuid

  sourceId      String?   @map("source_id") @db.Uuid
  sourceName    String?   @map("source_name") @db.VarChar(150)
  sourceUrl     String?   @map("source_url") @db.Text

  /// success, partial_success, failed
  status        String    @default("success") @db.VarChar(30)

  totalFound    Int       @default(0) @map("total_found")
  totalInserted Int       @default(0) @map("total_inserted")
  totalSkipped  Int       @default(0) @map("total_skipped")
  totalFailed   Int       @default(0) @map("total_failed")

  message       String?   @db.Text
  errorMessage  String?   @map("error_message") @db.Text

  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt    DateTime? @map("finished_at") @db.Timestamptz(6)

  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([sourceId])
  @@index([status])
  @@index([startedAt])
  @@map("news_fetch_logs")
}