{
  "name": "learnova-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:create": "node scripts/db/create-database.mjs",
    "db:test": "node scripts/db/test-connection.mjs",
    "db:reset": "node scripts/db/reset-database.mjs",
    "auth:sync-config": "bun --env-file=.env scripts/db/sync-auth-config-from-env.ts",
    "smtp:sync-config": "bun --env-file=.env scripts/db/sync-smtp-config-from-env.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:uat": "node scripts/test/run-uat.mjs",
    "seed:dev": "bun --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "crypto-js": "^4.2.0",
    "katex": "^0.17.0",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/nodemailer": "^8.0.1",
    "@types/crypto-js": "^4.2.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
